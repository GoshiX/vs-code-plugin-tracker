{
  "name": "vs-code-plugin-tracker",
  "displayName": "VS Code Tracker MVP",
  "description": "Local MVP for tracked coding sessions and encrypted activity logs.",
  "version": "1.0.0",
  "publisher": "local-demo",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:tracker.sidebar",
    "onCommand:tracker.startSession",
    "onCommand:tracker.finishSession",
    "onCommand:tracker.openAdmin",
    "onCommand:tracker.revealSessionFolder"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tracker",
          "title": "Трекер",
          "icon": "media/tracker.svg"
        }
      ]
    },
    "views": {
      "tracker": [
        {
          "id": "tracker.sidebar",
          "name": "Управление сессией",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "tracker.startSession",
        "title": "Трекер: Начать сессию"
      },
      {
        "command": "tracker.finishSession",
        "title": "Трекер: Завершить сессию"
      },
      {
        "command": "tracker.openAdmin",
        "title": "Трекер: Открыть админ-панель"
      },
      {
        "command": "tracker.revealSessionFolder",
        "title": "Трекер: Показать папку сессии"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
